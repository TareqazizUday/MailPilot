# Copy to `.env` in this folder (mailpilot/) and edit.
# Install: pip install -r requirements.txt
# Django: python manage.py migrate && python manage.py runserver 127.0.0.1:8000
# Flask (optional): python ../run.py from repo root — uses this folder for .env + data/

FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# Django
# DJANGO_DEBUG=true
# DJANGO_SECRET_KEY=change-me-in-production
# OAUTH redirect must match Google Cloud "Authorized redirect URIs" (host + port).
# OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/gmail/oauth/callback

# Gmail identity (your account)
GMAIL_ADDRESS=

# OAuth2 — place client_secret.json in this mailpilot/ folder or set path below
GOOGLE_CLIENT_SECRET_FILE=client_secret.json
GOOGLE_TOKEN_FILE=data/token.json

# Gmail polling
IMAP_POLL_SECONDS=120
GMAIL_QUERY_LABELS=INBOX

# Relevance routing (only handle service/website-related emails)
SERVICE_KEYWORDS=website, web, service, support, pricing, quote, meeting, schedule, appointment
SERVICE_BRAND_TOKENS=
SERVICE_SENDER_DOMAIN_ALLOWLIST=
SERVICE_SENDER_DOMAIN_BLOCKLIST=
RELEVANCE_THRESHOLD=2

# Reply behavior: draft | send | both
REPLY_MODE=send

# Outbound transport: gmail_api | smtp
SEND_TRANSPORT=gmail_api

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_VERIFY_TLS=true
SMTP_TLS_SERVERNAME=
SMTP_FROM_EMAIL=

# IMAP (optional — same mailbox as SMTP)
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_VERIFY_TLS=true
IMAP_TLS_SERVERNAME=

# LLM (OpenAI)
LLM_PROVIDER=openai
LLM_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_ENDPOINT=
LLM_TEMPERATURE=0.2

# Vector DB (Postgres + pgvector)
VECTOR_DB_DSN=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
