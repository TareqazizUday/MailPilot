# Copy to `.env` in this folder (mailpilot/) and edit.
# Install: pip install -r requirements.txt
# Django: python manage.py migrate && python manage.py runserver 127.0.0.1:8000
# Flask (optional): python ../run.py from repo root — uses this folder for .env + data/

FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# Django
# DJANGO_DEBUG=true
# DJANGO_SECRET_KEY=change-me-in-production
# OAUTH redirect must match Google Cloud "Authorized redirect URIs" (host + port).
# OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/gmail/oauth/callback

# Django database (PostgreSQL recommended)
# If you use `docker-compose.yml` in this repo, defaults are already set there.
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=mailpilot
DJANGO_DB_USER=mailpilot_user
DJANGO_DB_PASSWORD=mailpilot_password
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432
# If Docker maps Postgres to another host port (e.g. 5433:5432 because 5432 is taken), set DJANGO_DB_PORT=5433

# One-time DB bootstrap (python manage.py postgres_bootstrap): superuser password from PostgreSQL install
# POSTGRES_BOOTSTRAP_USER=postgres
# POSTGRES_BOOTSTRAP_PASSWORD=
 
# Gmail identity (your account)
GMAIL_ADDRESS=

# OAuth2 — place client_secret.json in this mailpilot/ folder or set path below
GOOGLE_CLIENT_SECRET_FILE=client_secret.json
GOOGLE_TOKEN_FILE=data/token.json

# Gmail polling
IMAP_POLL_SECONDS=120
GMAIL_QUERY_LABELS=INBOX

# Relevance routing (only handle service/website-related emails)
SERVICE_KEYWORDS=website, web, service, support, pricing, quote, meeting, schedule, appointment
SERVICE_BRAND_TOKENS=
SERVICE_SENDER_DOMAIN_ALLOWLIST=
SERVICE_SENDER_DOMAIN_BLOCKLIST=
RELEVANCE_THRESHOLD=2

# Reply behavior: draft | send | both
REPLY_MODE=send

# Outbound transport: gmail_api | smtp
SEND_TRANSPORT=gmail_api

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_VERIFY_TLS=true
SMTP_TLS_SERVERNAME=
SMTP_FROM_EMAIL=

# IMAP (optional — same mailbox as SMTP)
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_VERIFY_TLS=true
IMAP_TLS_SERVERNAME=

# LLM (OpenAI)
LLM_PROVIDER=openai
LLM_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_ENDPOINT=
LLM_TEMPERATURE=0.2

# Vector / KB (Postgres + pgvector). Empty VECTOR_DB_DSN = use same DB as DJANGO_DB_*.
# In DB: CREATE EXTENSION vector; — see docs/kb-pgvector-setup.md
VECTOR_DB_DSN=
# Real embeddings: set LLM_API_KEY or OPENAI_API_KEY. Use stub/off for dev zero-vectors.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
