<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <httpErrors errorMode="Detailed" existingResponse="PassThrough" />

    <security>
      <requestFiltering>
        <!-- Allow large uploads (up to ~2GB) -->
        <requestLimits maxAllowedContentLength="2147483648" />
      </requestFiltering>
    </security>

    <!-- Reverse proxy to Django (Waitress) on 127.0.0.1:8011 -->
    <!-- Do not set serverVariables here unless IIS "Allowed Server Variables" includes them (otherwise 500 URL Rewrite Module Error). -->
    <rewrite>
      <rules>
        <rule name="DjangoReverseProxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:8011/{R:1}" />
          <!-- Optional: uncomment after running setup_iis_mailpilot_site.ps1 as Administrator.
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
          </serverVariables>
          -->
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
